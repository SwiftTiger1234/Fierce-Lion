/* ==================== 🌈 GENERAL BODY STYLING ==================== */
body {
  text-align: center; /* Centers text inside the body */
  font-size: 35px; /* Base font size for text */
  font-weight: 10000; /* Extra bold text (higher = bolder) */
  background-color: blue; /* Fallback background color */
  margin-top: 0; /* Removes white gap at the very top */
  margin-left: 0; /* Removes white gap on the left */
  margin-right: 0; /* Removes white gap on the right */
  background: linear-gradient(120deg, skyblue, yellow); /* Gradient background for body */
}

/* ==================== 🔵 MAIN HEADING STYLING ==================== */
h1 {
  color: blue; /* Text color for headings */
  font-size: 45px; /* Heading size */
  font-weight: 10000; /* Very bold text */
  font-style: oblique; /* Slightly slanted text */
  margin-top: 0; /* Removes gap above heading */
  margin-bottom: 0; /* Removes gap below heading */
  font-family: sans-serif; /* Sets a clean default font (you can change this) */
}

/* ==================== 🎨 TOP SECTION (HEADER AREA) ==================== */
.TopSection {
  background: linear-gradient(120deg, #ff99df, #66ffff); /* Gradient background for top */
  box-shadow:
    0 0 20px #ffffff,  /* Soft white glow */
    0 0 40px #ff6ec4,  /* Pink glow */
    0 0 60px #7873f5;  /* Purple glow */
}

/* ==================== ☁️ CLOUD IMAGES ==================== */
.cloudA {
  height: 50px; /* Size of cloud A */
  position: absolute; /* Positioned freely on the page */
  top: 40%; /* Moves it 40% from the top */
  left: 10%; /* Moves it 10% from the left */
}

.cloudB {
  height: 50px; /* Size of cloud B */
  position: absolute; /* Positioned freely on the page */
  top: 75%; /* Moves it down 75% */
  left: 80%; /* Moves it 80% from the left */
}

/* ==================== 🌍 LAND IMAGE ==================== */
.land {
  margin: 0; /* Ensures land image sits neatly without extra space */
  margin: 0;           /* removes top and bottom margin */
  padding: 0;          /* removes extra padding if any */

  border: none;        /* optional: removes default border */

}

/* ==================== 👩 PROFILE IMAGE (ARA) ==================== */
.Ara {
  border-radius: 70%; /* Makes profile image rounded (circular) */
  border-width: thin; /* Thin border */
  height: 200px; /* Height of image */
  width: auto; /* Auto width to keep proportions */
}

/* ==================== 🔘 BUTTON CONTAINER ==================== */
.button {
  text-align: center; /* Aligns all buttons in the middle */
  border: none; /* Removes unwanted borders */
  margin: 20px; /* Space outside the button group */
  padding: 20px; /* Space inside the button group */
}

/* ==================== 🔘 NAVIGATION BUTTONS ==================== */
button.b {
  position: fixed; /* Stays in place when scrolling */
  top: 0; /* Sticks to the very top */
  left: 0; /* Sticks to the very left */
  width: 100%; /* Stretches across the screen */
  text-align: center; /* Centers button text */
  margin-top: 0; /* Removes extra gap at the top */
  border: none; /* Removes border */
  border-radius: 30px; /* Rounds the button edges */
}

/* ==================== 📖 BIO SECTION ==================== */
.Bio {
  margin-top: 0; /* Removes unwanted top margin */
}

