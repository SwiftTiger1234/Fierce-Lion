/* 🎀 Calculator container box */
.calculator {
  background: pink;              /* White background */
  padding: 15px;                 /* Space inside */
  border-radius: 20px;           /* Rounded corners */
  box-shadow: 0 6px 16px rgba(0,0,0,0.15); /* Soft shadow for 3D look */
  width: 260px;                  /* Fixed width */
  height: 260px;                 /* Fixed height (square shape) */
  display: flex;                 /* Flexbox layout */
  flex-direction: column;        /* Stack items vertically */
  justify-content: space-between;/* Even spacing top to bottom */
}

/* 📟 Display screen */
.calculator .display {
  width: 90%;                   /* Full width of container */
  height: 40px;                  /* Height of display */
  margin-bottom: 10px;           /* Space below display */
  border: 1px solid #ddd;        /* Light grey border */
  border-radius: 12px;           /* Rounded corners */
  padding: 8px;                  /* Space inside text box */
  text-align: right;             /* Numbers align to the right */
  font-size: 18px;               /* Text size */
}

/* 🔲 Buttons grid */
.calculator .buttons {
  flex: 1;                       /* Take remaining space */
  display: grid;                 /* Grid layout */
  grid-template-columns: repeat(4, 1fr); /* 4 equal columns */
  grid-template-rows: repeat(4, 1fr);    /* 4 equal rows */
  gap: 6px;                      /* Space between buttons */
}

/* 🔘 All buttons */
.calculator button {
  border: none;                  /* Remove default button border */
  border-radius: 12px;           /* Rounded buttons */
  background: #f0d9ff;           /* Light purple background */
  font-size: 16px;               /* Text size */
  cursor: pointer;               /* Hand cursor on hover */
  transition: 0.2s;              /* Smooth hover effect */
}

/* 🌸 Button hover effect */
.calculator button:hover {
  background: #d8bfff;           /* Slightly darker purple when hovered */
}

/* 🟩 Equal button (spans 2 columns wide) */
.calculator .equal {
  grid-column: span 2;           /* Makes "=" button twice as wide */
  background: #c1f7d5;           /* Green background */
}

/* 🌱 Equal hover effect */
.calculator .equal:hover {
  background: #9ae6b4;           /* Darker green on hover */
}

































